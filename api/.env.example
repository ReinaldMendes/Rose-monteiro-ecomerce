# Banco de dados Railway PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# JWT - gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="sua-chave-jwt-super-secreta-aqui"
JWT_EXPIRES_IN="7d"

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# E-mail (Nodemailer / Gmail ou SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seuemail@gmail.com"
SMTP_PASS="sua-senha-de-app"
EMAIL_FROM="Rose Monteiro Joias <noreply@rosemonteiro.com.br>"
EMAIL_ADMIN="contato@rosemonteiro.com.br"

# WhatsApp (número da Rose para receber notificações)
WHATSAPP_NUMBER="5542999999999"

# Frontend URL (para CORS)
FRONTEND_URL="https://www.ceramicasrosemonteiro.com.br"

# Ambiente
NODE_ENV="production"
PORT=3001
